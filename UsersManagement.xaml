<Window x:Class="Pekarna_Xlebus.UsersManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pekarna_Xlebus"
        mc:Ignorable="d"
       Title="Управление пользователями" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Height="60" Background="#3498DB">
            <TextBlock Text="Управление пользователями" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        
        <!-- Список пользователей -->
        <ListBox x:Name="lstUsers" Grid.Row="1" Margin="10">
            <ListBoxItem>1. Иван Петров (Администратор)</ListBoxItem>
            <ListBoxItem>2. Елена Соколова (Администратор)</ListBoxItem>
            <ListBoxItem>3. Сергей Павлов (Пользователь)</ListBoxItem>
            <ListBoxItem>4. Алексей Сидоров (Пользователь)</ListBoxItem>
            <ListBoxItem>5. Ольга Лебедева (Пользователь)</ListBoxItem>
        </ListBox>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="100" Height="35" Margin="5" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" Click="BtnDelete_Click"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

