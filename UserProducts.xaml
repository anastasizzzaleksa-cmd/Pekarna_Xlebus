<Window x:Class="Pekarna_Xlebus.UserProducts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pekarna_Xlebus"
        mc:Ignorable="d"
        Title="Управление товарами" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Height="60" Background="#27AE60">
            <TextBlock Text="Управление товарами" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Список товаров -->
        <ListBox x:Name="lstProducts" Grid.Row="1" Margin="10">
            <ListBoxItem>1. Булочка с Изюмом 200г - 89.99 ₽</ListBoxItem>
            <ListBoxItem>2. Хлеб белый 300г - 59.99 ₽</ListBoxItem>
            <ListBoxItem>3. Булочка с яблоком 200г - 89.99 ₽</ListBoxItem>
            <ListBoxItem>4. Булочка с вишней - 99.99 ₽</ListBoxItem>
            <ListBoxItem>5. Пироженое красный бархат - 149.99 ₽</ListBoxItem>
            <ListBoxItem>6. Пироженое черная ночь - 149.99 ₽</ListBoxItem>
        </ListBox>
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" Click="BtnAdd_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" Click="BtnDelete_Click"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
