<Window x:Class="Pekarna_Xlebus.Clients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pekarna_Xlebus"
        mc:Ignorable="d"
        Title="Просмотр клиентов" Height="450" Width="600" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Height="60" Background="#3498DB">
            <TextBlock Text="Просмотр клиентов" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        
        <!-- Список клиентов -->
        <ListBox x:Name="lstClients" Grid.Row="1" Margin="10">
            <ListBoxItem>1. ООО Поставка, г.Пятигорск +79198634592 </ListBoxItem>
            <ListBoxItem>2. ООО "Новый JDTO, г. Железноводсу, +79884581555 </ListBoxItem>
            <ListBoxItem Width="570">3. ООО Кинотеатр Квант, инн: 26320045123, г. Железноводск, ул. Мира, 123,+79884581555 </ListBoxItem>
            <ListBoxItem>4. ООО Ромашка, инн: 4140784214, г. Омск, ул. Строителей, 294,+79882584546 </ListBoxItem>
            <ListBoxItem>5. ООО Ипподром, инн: 5874045632, г. Уфа, ул. Набережная,  37, +79627486389 </ListBoxItem>
        </ListBox>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnViewDetails" Content="Просмотреть детали" Width="150" Height="35" Margin="5" Background="#3498DB" Foreground="White" Click="BtnViewDetails_Click"/>
            <Button x:Name="btnViewOrders" Content="История заказов" Width="150" Height="35" Margin="5" Background="#27AE60" Foreground="White" Click="BtnViewOrders_Click"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>