<Window x:Class="Pekarna_Xlebus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pekarna_Xlebus"
        mc:Ignorable="d"
        Title="Авторизация" Height="550" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
 
     
        <Border Grid.Row="1" Margin="50,40,50,40" Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel Margin="30">
                <TextBlock Text="Авторизация" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <!-- Логин -->
                <TextBlock Text="Логин" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                <TextBox x:Name="txtLogin" FontSize="14" Padding="10">
                    <TextBox.Effect>
                        <DropShadowEffect BlurRadius="3" Opacity="0.1"/>
                    </TextBox.Effect>
                </TextBox>
        
                <TextBlock Text="Пароль" Foreground="#7F8C8D" Margin="0,15,0,5"/>
                <PasswordBox x:Name="txtPassword" FontSize="14" Padding="10">
                    <PasswordBox.Effect>
                        <DropShadowEffect BlurRadius="3" Opacity="0.1"/>
                    </PasswordBox.Effect>
                </PasswordBox>
                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button x:Name="btnLogin" Content="Войти" Width="120" Height="40" Click="BtnLogin_Click" Margin="0,0,10,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
